			    Log_Write("log_give", "%s (uid: %i) has sold their %i repair kit tool to %s (uid: %i) for $%i.", GetPlayerNameEx(offeredby), PlayerInfo[offeredby][pID], amount, GetPlayerNameEx(playerid), PlayerInfo[playerid][pID], price);

