                cache_get_field_content(i, "message", BusinessInfo[i][bMessage], connectionID, 128);
				BusinessInfo[i][bRobbed] = cache_get_field_content_int(i, "robbed");
				BusinessInfo[i][bRobbing] = cache_get_field_content_int(i, "robbing");

				BusinessInfo[i][bSupplyPos][0] = cache_get_field_content_float(i, "bizDeliverX");
                BusinessInfo[i][bSupplyPos][1]= cache_get_field_content_float(i, "bizDeliverY");
                BusinessInfo[i][bSupplyPos][2] = cache_get_field_content_float(i, "bizDeliverZ");

				new str[64], tmp[128];
                for (new j = 0; j < 25; j ++)
                {
                    if(BusinessInfo[i][bPrices] == 1500)
                    {
                        SetBusinessProducts(i);
                    }
                    else
                    {
                        format(str, 32, "prices%d", j);
                        BusinessInfo[i][bPrices][j] = cache_get_field_content_int(i, str);
                    }
                }
				// Dealership
				if(BusinessInfo[i][bType] == BUSINESS_DEALERSHIP)
				{
					for (new j, column[16], label[1024]; j < MAX_BUSINESS_DEALERSHIP_VEHICLES; j++)
					{
					    format(column, sizeof(column), "Car%dModelId", j);
						cache_get_field_content(i, column, tmp, connectionID); BusinessInfo[i][bModel][j] = strval(tmp);
					    format(column, sizeof(column), "Car%dPosX", j);
						cache_get_field_content(i, column, tmp, connectionID); BusinessInfo[i][bParkPosX][j] = floatstr(tmp);
					    format(column, sizeof(column), "Car%dPosY", j);
						cache_get_field_content(i, column, tmp, connectionID); BusinessInfo[i][bParkPosY][j] = floatstr(tmp);
					    format(column, sizeof(column), "Car%dPosZ", j);
						cache_get_field_content(i, column, tmp, connectionID); BusinessInfo[i][bParkPosZ][j] = floatstr(tmp);
					    format(column, sizeof(column), "Car%dPosAngle", j);
						cache_get_field_content(i, column, tmp, connectionID); BusinessInfo[i][bParkAngle][j] = floatstr(tmp);
					    format(column, sizeof(column), "Car%dPrice", j);
						cache_get_field_content(i, column, tmp, connectionID); BusinessInfo[i][bVPrice][j] = strval(tmp);

						cache_get_field_content(i, "PurchaseX", tmp, connectionID); BusinessInfo[i][bPurchaseX][j] = strval(tmp);
						cache_get_field_content(i, "PurchaseY", tmp, connectionID); BusinessInfo[i][bPurchaseY][j] = strval(tmp);
						cache_get_field_content(i, "PurchaseZ", tmp, connectionID); BusinessInfo[i][bPurchaseZ][j] = strval(tmp);
						cache_get_field_content(i, "PurchaseAngle", tmp, connectionID); BusinessInfo[i][bPurchaseAngle][j] = strval(tmp);

		                if(400 < BusinessInfo[i][bModel][j] < 612)
		                {
					 		BusinessInfo[i][bVehID][j] = CreateVehicle(BusinessInfo[i][bModel][j], BusinessInfo[i][bParkPosX][j], BusinessInfo[i][bParkPosY][j], BusinessInfo[i][bParkPosZ][j], BusinessInfo[i][bParkAngle][j], BusinessInfo[i][bColor1][j], BusinessInfo[i][bColor2][j], 10);
		     				format(label, sizeof(label), "Vehicle For sale\nGet inside the vehicle for more information");
							BusinessInfo[i][bVehicleLabel][j] = CreateDynamic3DTextLabel(label,COLOR_LIGHTBLUE,BusinessInfo[i][bParkPosX][j], BusinessInfo[i][bParkPosY][j], BusinessInfo[i][bParkPosZ][j],8.0,INVALID_PLAYER_ID, BusinessInfo[i][bVehID][j]);
						}
					}
				}
                ReloadBusiness(i);
		    }

		    printf("[MySQL] %i businesses loaded.", rows);
		}
