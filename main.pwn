	 		if(!response) return 1;
			new
				szMessage[150];
	   		if(strlen(inputtext) < 1)
			{
	            format(szMessage, sizeof(szMessage), "You must enter the check code before signing.\n\nCheck code: %d\n\nEnter your check code to receive your paycheck:", PlayerInfo[playerid][pPaycheckCode]);
				ShowPlayerDialog(playerid, DIALOG_PAYCHECK, DIALOG_STYLE_INPUT, SERVER_DIALOG, szMessage, "Paycheck","Cancel");
				return 1;
	        }
			if(!IsNumeric(inputtext))
			{
	 			format(szMessage, sizeof(szMessage), "Wrong check code. The check code consists out of numbers only.\n\nCheck code: %d\n\nEnter your check code to receive your paycheck:", PlayerInfo[playerid][pPaycheckCode]);
				ShowPlayerDialog(playerid, DIALOG_PAYCHECK, DIALOG_STYLE_INPUT, SERVER_DIALOG, szMessage, "Paycheck","Cancel");
				return 1;
			}
	        if(strlen(inputtext) > 6 || (strlen(inputtext) > 0 && strlen(inputtext) < 6))
			{
	           	format(szMessage, sizeof(szMessage), "Wrong check code. The check code consists out of 6 digits.\n\nCheck code: %d\n\nEnter your check code to receive your paycheck:", PlayerInfo[playerid][pPaycheckCode]);
				ShowPlayerDialog(playerid, DIALOG_PAYCHECK, DIALOG_STYLE_INPUT, SERVER_DIALOG, szMessage, "Paycheck","Cancel");
				return 1;
	        }
	        new code = strval(inputtext);
        	if(code == PlayerInfo[playerid][pPaycheckCode])
	        {
				SendPaycheck(playerid);
	        	PlayerInfo[playerid][pPaycheckCode] = 0;
			}
			else
			{
	            SendClientMessage(playerid, COLOR_WHITE, "Wrong check code.");
	        }
		}
