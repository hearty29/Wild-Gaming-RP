			SendClientMessage(playerid, COLOR_WHITE, ""SVRCLR"[SERVER]: "WHITE"Double SALARY starts at {008000}21:00"WHITE" and ends at {FF0000}24:00"WHITE", SERVER TIME");*/
		}
		else
		{
		    SendClientMessage(playerid, COLOR_YELLOW, "______________________________LRPDOUBLE SALARY SYSTEM("GREEN"ACTIVE"YELLOW")______________________________");
			SendClientMessage(playerid, COLOR_WHITE, ""SVRCLR"[SERVER]: "WHITE"Double SALARY starts at {008000}3:00"WHITE" and ends at {FF0000}6:00"WHITE", SERVER TIME");
			SendClientMessage(playerid, COLOR_WHITE, ""SVRCLR"[SERVER]: "WHITE"Double SALARY starts at {008000}9:00"WHITE" and ends at {FF0000}12:00"WHITE", SERVER TIME");
			SendClientMessage(playerid, COLOR_WHITE, ""SVRCLR"[SERVER]: "WHITE"Double SALARY starts at {008000}15:00"WHITE" and ends at {FF0000}18:00"WHITE", SERVER TIME");
			SendClientMessage(playerid, COLOR_WHITE, ""SVRCLR"[SERVER]: "WHITE"Double SALARY starts at {008000}21:00"WHITE" and ends at {FF0000}24:00"WHITE", SERVER TIME");
		}
		return 1;
	}
	if(!strcmp(option, "exp", true))
	{
	    if(!gDoubleXP)
	    {
	        SendClientMessage(playerid, COLOR_YELLOW, "______________________________""LRPDOUBLE XP SYSTEM("RED"NOT ACTIVE"YELLOW")_________________________________");
		/*	SendClientMessage(playerid, COLOR_WHITE, ""SVRCLR"[SERVER]: "WHITE"Double XP starts at {008000}0:00"WHITE" and ends at {FF0000}3:00"WHITE", SERVER TIME");
		    SendClientMessage(playerid, COLOR_WHITE, ""SVRCLR"[SERVER]: "WHITE"Double XP starts at {008000}6:00"WHITE" and ends at {FF0000}9:00"WHITE", SERVER TIME");
		    SendClientMessage(playerid, COLOR_WHITE, ""SVRCLR"[SERVER]: "WHITE"Double XP starts at {008000}12:00"WHITE" and ends at {FF0000}15:00"WHITE", SERVER TIME");
		    SendClientMessage(playerid, COLOR_WHITE, ""SVRCLR"[SERVER]: "WHITE"Double XP starts at {008000}18:00"WHITE" and ends at {FF0000}21:00"WHITE", SERVER TIME");*/
		}
		else
		{
		    SendClientMessage(playerid, COLOR_YELLOW, "______________________________""LRPDOUBLE XP SYSTEM("GREEN"Active"YELLOW")_________________________________");
		/*	SendClientMessage(playerid, COLOR_WHITE, ""SVRCLR"[SERVER]: "WHITE"Double XP starts at {008000}0:00"WHITE" and ends at {FF0000}3:00"WHITE", SERVER TIME");
		    SendClientMessage(playerid, COLOR_WHITE, ""SVRCLR"[SERVER]: "WHITE"Double XP starts at {008000}6:00"WHITE" and ends at {FF0000}9:00"WHITE", SERVER TIME");
		    SendClientMessage(playerid, COLOR_WHITE, ""SVRCLR"[SERVER]: "WHITE"Double XP starts at {008000}12:00"WHITE" and ends at {FF0000}15:00"WHITE", SERVER TIME");
		    SendClientMessage(playerid, COLOR_WHITE, ""SVRCLR"[SERVER]: "WHITE"Double XP starts at {008000}18:00"WHITE" and ends at {FF0000}21:00"WHITE", SERVER TIME");*/
		}
		return 1;
	}
	return 1;
}

