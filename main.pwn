			SendMessage(playerid, COLOR_SYNTAX, "SERVER: You set you bind slot 6 To:%s.",(PlayerInfo[playerid][pBind6]));

			mysql_format(connectionID, queryBuffer, sizeof(queryBuffer), "UPDATE users SET bindslot6 = '%s' WHERE uid = %i", PlayerInfo[playerid][pBind6], PlayerInfo[playerid][pID]);
