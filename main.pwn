			Medic: /movept, /badge, /gov, /backup, /listcallers, /trackcall, /d, /callsign, /undeployall, /heal.\n\
			Auto: /po.");
			ShowPlayerDialog(playerid, DIALOG_FHELP, DIALOG_STYLE_MSGBOX, "Factions Command List", string, "Like!","Back");
		}
		case FACTION_NEWS:
