					mysql_format(connectionID, queryBuffer, sizeof(queryBuffer), "SELECT * FROM `inventory` WHERE `ownerID` = '%d'", PlayerInfo[extraid][pID]);
					mysql_tquery(connectionID, queryBuffer, "LoadPlayerInventory", "d", extraid);

