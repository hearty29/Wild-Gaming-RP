// DealershipDealership
CMD:createcdveh(playerid, const params[])
{
	new iBusiness, iVehicle, iColors[2], Float: fVehPos[4], label[50], model[20];
	if(PlayerInfo[playerid][pAdmin] < 7)
		return SendClientMessage(playerid, COLOR_GREY, "You are not authorized to use that command.");
	
	if(sscanf(params, "is[20]ii", iBusiness, model, iColors[0], iColors[1]))
		return SendClientMessage(playerid, COLOR_GREY, "USAGE: /createcdveh [business ID] [model id] [color 1] [color 2]");
	
	if((iVehicle = GetVehicleModelByName(model)) == 0)
	    return SendClientMessage(playerid, COLOR_SYNTAX, "Invalid vehicle model.");
	
	if(!(-1 <= iColors[0] <= 255) || !(-1 <= iColors[1] <= 255))
	    return SendClientMessage(playerid, COLOR_SYNTAX, "Invalid color. Valid colors range from -1 to 255.");
	
	if(BusinessInfo[iBusiness][bType] != BUSINESS_DEALERSHIP)
		return SendClientMessage(playerid, COLOR_GREY, "Business is not a car dealership!");
	
	for(new i; i < MAX_BUSINESS_DEALERSHIP_VEHICLES; i++)
	{
		if(BusinessInfo[iBusiness][bVehID][i] == 0)
		{
			GetPlayerPos(playerid, fVehPos[0], fVehPos[1], fVehPos[2]);
			GetPlayerFacingAngle(playerid, fVehPos[3]);
			BusinessInfo[iBusiness][bVehID][i] = CreateVehicle(iVehicle, fVehPos[0], fVehPos[1], fVehPos[2], fVehPos[3], iColors[0], iColors[1], -1);

			BusinessInfo[iBusiness][bModel][i] = iVehicle;

			BusinessInfo[iBusiness][bParkPosX][i] = fVehPos[0];
			BusinessInfo[iBusiness][bParkPosY][i] = fVehPos[1];
			BusinessInfo[iBusiness][bParkPosZ][i] = fVehPos[2];
			BusinessInfo[iBusiness][bParkAngle][i] = fVehPos[3];

			format(label, sizeof(label), "%s For Sale | Price: $%s", GetVehicleName(BusinessInfo[iBusiness][bVehID][i]), number_format(BusinessInfo[iBusiness][bVPrice][i]));
			BusinessInfo[iBusiness][bVehicleLabel][i] = CreateDynamic3DTextLabel(label,COLOR_LIGHTBLUE,BusinessInfo[iBusiness][bParkPosX][i], BusinessInfo[iBusiness][bParkPosY][i], BusinessInfo[iBusiness][bParkPosZ][i],8.0,INVALID_PLAYER_ID, BusinessInfo[iBusiness][bVehID][i]);

			BusinessInfo[iBusiness][DealershipVehStock][i] = 1;
			SaveDealershipVehicle(iBusiness, i);
			return 1;
		}
	}
	return 1;
}

CMD:editcarspawn(playerid, const params[])
{
	new businessid;
	if(PlayerInfo[playerid][pAdmin] < 7)
		return SendClientMessage(playerid, COLOR_GREY, "You are not authorized to use that command.");
	
	if(sscanf(params, "i", businessid))
		return SendClientMessage(playerid, COLOR_GREY, "USAGE: /editcarspawn [business ID]");
	
	new Float: Positionsz[4];
	GetPlayerPos(playerid, Positionsz[0], Positionsz[1], Positionsz[2]);
	GetPlayerFacingAngle(playerid, Positionsz[3]);
	BusinessInfo[businessid][bPurchaseX] = Positionsz[0];
	BusinessInfo[businessid][bPurchaseY] = Positionsz[1];
	BusinessInfo[businessid][bPurchaseZ] = Positionsz[2];
	BusinessInfo[businessid][bPurchaseAngle] = Positionsz[3];
	SendClientMessage(playerid, COLOR_WHITE, "You have moved the vehicle purchase spawn location.");
	SaveDealershipSpawn(businessid);
	return 1;
}

CMD:dealershiprespawn(playerid, const params[])
{
	new businessid = GetInsideBusiness(playerid);
	if(businessid == -1 || !IsBusinessOwner(playerid, businessid))
	    return SendClientMessage(playerid, COLOR_SYNTAX, "You're not near any business that you own.");

	SendClientMessage(playerid, COLOR_GREY, "Respawning dealership vehicles..");

	for (new i; i < MAX_BUSINESS_DEALERSHIP_VEHICLES; i++)
	{
		if(BusinessInfo[businessid][bVehID][i] != 0) SetVehicleToRespawn(BusinessInfo[businessid][bVehID][i]);
	}
	return 1;
}

CMD:editcarprice(playerid, const params[])
{
	new businessid, vehicleid, amount;
	if(PlayerInfo[playerid][pAdmin] < 7)
		return SendClientMessage(playerid, COLOR_GREY, "You are not authorized to use that command.");

	if(sscanf(params, "ddd", businessid, vehicleid, amount)) 
		return SendClientMessage(playerid, COLOR_GREY, "USAGE: /editcarprice [Business ID] [Vehicle ID] [Price]");
		
	else if(businessid != GetCarBusiness(vehicleid))
		return SendClientMessage(playerid, COLOR_GREY, "That vehicle is not part of your dealership.");
	
	else if(amount < 0) 
		return SendClientMessage(playerid, COLOR_GREY, "The price can't be set below 0");

	new iSlot = GetBusinessCarSlot(vehicleid), Message[128];

	BusinessInfo[businessid][bVPrice][iSlot] = amount;
	format(Message, sizeof(Message), "%s For Sale | Price: $%s", GetVehicleName(BusinessInfo[businessid][bVehID][iSlot]), number_format(BusinessInfo[businessid][bVPrice][iSlot]));
	UpdateDynamic3DTextLabelText(BusinessInfo[businessid][bVehicleLabel][iSlot], COLOR_LIGHTBLUE, Message);
	format(Message, sizeof(Message), "%s price has been set to $%s", GetVehicleName(vehicleid), number_format(amount));
	SendClientMessage(playerid, COLOR_WHITE, Message);
	SaveDealershipVehicle(businessid, iSlot);
	return 1;
}

CMD:deletecdveh(playerid, const params[]) {
	if(PlayerInfo[playerid][pAdmin] >= 7) {

		new
		    iBusiness,
			iVehicle;

		if(sscanf(params, "ii", iBusiness, iVehicle )) {
			return SendClientMessage(playerid, COLOR_GREY, "USAGE: /deletecdveh [business ID] [Model ID]");
		}
		else if(BusinessInfo[iBusiness][bType] != BUSINESS_DEALERSHIP) {
			return SendClientMessage(playerid, COLOR_GREY, "Business is not a car dealership!");
		}
		else if(iBusiness != GetCarBusiness(iVehicle)) {
			return SendClientMessage(playerid, COLOR_GREY, "That vehicle isn't a dealership vehicle.");
		}
		else {

			new
				ID = GetBusinessCarSlot(iVehicle);

			if(BusinessInfo[iBusiness][bVehID][ID] != INVALID_VEHICLE_ID) {
			    if(IsValidDynamic3DTextLabel(BusinessInfo[iBusiness][bVehicleLabel][ID])) DestroyDynamic3DTextLabel(BusinessInfo[iBusiness][bVehicleLabel][ID]), BusinessInfo[iBusiness][bVehicleLabel][ID] = Text3D:-1;
                DestroyVehicle(BusinessInfo[iBusiness][bVehID][ID]);
               	BusinessInfo[iBusiness][bModel][ID] = 0;
				BusinessInfo[iBusiness][bParkPosX][ID] = 0;
  				BusinessInfo[iBusiness][bParkPosY][ID] = 0;
			   	BusinessInfo[iBusiness][bParkPosZ][ID] = 0;
		   	 	BusinessInfo[iBusiness][bParkAngle][ID] = 0;
		   	 	BusinessInfo[iBusiness][bVehID][ID] = 0;
		   	 	BusinessInfo[iBusiness][bVPrice][ID] = 0;
		   	 	SaveDealershipVehicle(iBusiness, ID);
	   	 		return 1;
       		}
			return SendClientMessage(playerid, COLOR_GREY, "The max number of vehicles for this business has been reached.");
		}
	}
	else SendClientMessage(playerid, COLOR_GREY, "You are not authorized to use that command.");
	return 1;
}

CMD:products(playerid, parmas[]) {

    new businessid = GetInsideBusiness(playerid), string[1024], title[64];
    if(businessid == -1 || !IsBusinessOwner(playerid, businessid))
	{
	    return SendClientMessage(playerid, COLOR_SYNTAX, "You're not near any business that you own.");
	}
	format(title, sizeof(title), "%s's %s (( %i Products ))", BusinessInfo[businessid][bOwner], bizInteriors[BusinessInfo[businessid][bType]][intType], BusinessInfo[businessid][bProducts]);
	switch(BusinessInfo[businessid][bType])
	{
	    case BUSINESS_STORE:
	    {
			format(string, sizeof(string), "Mobile Phone\t%s\nPortable Radio\t%s\nCigars\t%s\nSpraycans\t%s\nPhonebook\t%s\nCamera\t%s\nMP3 player\t%s\nFishing rod\t%s\nFish bait\t%s\nMuriatic acid\t%s\nBaking soda\t%s\nPocket watch\t%s\nGPS system\t%s\nGasoline can\t%s\nRope\t%s\nBlindfold\t%s\nToolkit\t%s\nFlashlight\t%s\nLottery Ticket\t%s\nMask\t%s\nCompass\t%s",
