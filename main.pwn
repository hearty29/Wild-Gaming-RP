CMD:doublesalary(playerid, const params[])
{
    if(PlayerInfo[playerid][pAdmin] < 7)
	{
	    return SendClientMessage(playerid, COLOR_SYNTAX, "You are not authorized to use this command.");
	}

	if(!gDoubleSalary)
	{
		gDoubleSalary = true;
		SendRconCommand("hostname\t"SERVER_NAME" [2x Salary]");
	    SendMessageToAll(COLOR_WHITE, "(( Administrator %s: has enabled double salary. You will now gain double of any jobs salary ))", GetRPName(playerid));
	}
	else
	{
		gDoubleSalary = false;
		SendRconCommand("hostname\t"SERVER_NAME"");
	    SendMessageToAll(COLOR_WHITE, "(( Administrator %s: has disable double salary ))", GetRPName(playerid));
	}

	return 1;
}

CMD:doublexp(playerid, const params[])
{
    if(PlayerInfo[playerid][pAdmin] < 7)
	{
	    return SendClientMessage(playerid, COLOR_SYNTAX, "You are not authorized to use this command.");
	}

	if(!gDoubleXP)
	{
		gDoubleXP = true;
		SendRconCommand("hostname\t"SERVER_NAME" [2x Experience]");
	    SendMessageToAll(COLOR_WHITE, "(( Administrator %s: has enabled double experience. You will now gain double the respect points and job skill points ))", GetRPName(playerid));
	}
	else
	{
		gDoubleXP = false;
		SendRconCommand("hostname\t"SERVER_NAME"");
	    SendMessageToAll(COLOR_WHITE, "(( Administrator %s: has disable double experience ))", GetRPName(playerid));
	}
	return 1;
}

CMD:checkdoublesalary(playerid, const params[])
{
    if(!gDoubleSalary)
    {
        SendClientMessage(playerid, COLOR_YELLOW, "______________________________LRPDOUBLE SALARY SYSTEM______________________________");
		SendClientMessage(playerid, COLOR_WHITE, ""SVRCLR"[SERVER]: "WHITE"Double SALARY starts at {008000}3:00"WHITE" and ends at {FF0000}6:00"WHITE", SERVER TIME ("RED"Not Active"WHITE")");
		SendClientMessage(playerid, COLOR_WHITE, ""SVRCLR"[SERVER]: "WHITE"Double SALARY starts at {008000}9:00"WHITE" and ends at {FF0000}12:00"WHITE", SERVER TIME ("RED"Not Active"WHITE")");
		SendClientMessage(playerid, COLOR_WHITE, ""SVRCLR"[SERVER]: "WHITE"Double SALARY starts at {008000}15:00"WHITE" and ends at {FF0000}18:00"WHITE", SERVER TIME ("RED"Not Active"WHITE")");
		SendClientMessage(playerid, COLOR_WHITE, ""SVRCLR"[SERVER]: "WHITE"Double SALARY starts at {008000}21:00"WHITE" and ends at {FF0000}24:00"WHITE", SERVER TIME ("RED"Not Active"WHITE")");
	}
	else
	{
	    SendClientMessage(playerid, COLOR_YELLOW, "______________________________LRPDOUBLE SALARY SYSTEM______________________________");
		SendClientMessage(playerid, COLOR_WHITE, ""SVRCLR"[SERVER]: "WHITE"Double SALARY starts at {008000}3:00"WHITE" and ends at {FF0000}6:00"WHITE", SERVER TIME ("GREEN"Active"WHITE")");
		SendClientMessage(playerid, COLOR_WHITE, ""SVRCLR"[SERVER]: "WHITE"Double SALARY starts at {008000}9:00"WHITE" and ends at {FF0000}12:00"WHITE", SERVER TIME ("GREEN"Active"WHITE")");
		SendClientMessage(playerid, COLOR_WHITE, ""SVRCLR"[SERVER]: "WHITE"Double SALARY starts at {008000}15:00"WHITE" and ends at {FF0000}18:00"WHITE", SERVER TIME ("GREEN"Active"WHITE")");
		SendClientMessage(playerid, COLOR_WHITE, ""SVRCLR"[SERVER]: "WHITE"Double SALARY starts at {008000}21:00"WHITE" and ends at {FF0000}24:00"WHITE", SERVER TIME ("GREEN"Active"WHITE")");
	}
	return 1;
}

CMD:startdoublesalary(playerid, const params[])
{
    new option[10];
	if(sscanf(params, "s[10]", option))
	{
	    SendClientMessage(playerid, COLOR_NEWS, "Command: /double [option]");
		SendClientMessage(playerid, COLOR_NEWS, "Available Options: Salary, Exp");
		return 1;
	}
	if(!strcmp(option, "salary", true))
	{
     	if(!gDoubleSalary)
	    {
	        SendClientMessage(playerid, COLOR_YELLOW, "______________________________LRPDOUBLE SALARY SYSTEM("RED"NOT ACTIVE"YELLOW")______________________________");
	   		/*SendClientMessage(playerid, COLOR_WHITE, ""SVRCLR"[SERVER]: "WHITE"Double SALARY starts at {008000}3:00"WHITE" and ends at {FF0000}6:00"WHITE", SERVER TIME");
			SendClientMessage(playerid, COLOR_WHITE, ""SVRCLR"[SERVER]: "WHITE"Double SALARY starts at {008000}9:00"WHITE" and ends at {FF0000}12:00"WHITE", SERVER TIME");
