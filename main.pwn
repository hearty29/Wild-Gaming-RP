							cache_get_field_content(i, "lastlogin", lastlogin);

							SendMessage(extraid, COLOR_WHITE, "%s", gServerMOTD);	
							SendMessage(extraid, COLOR_SYNTAX, "Welcome to "SERVER_NAME" %s, Your Last Login was on %s", GetRPName(extraid), lastlogin);
						}
					}

					if(PlayerInfo[extraid][pFaction] >= 0 && FactionInfo[PlayerInfo[extraid][pFaction]][fType] == FACTION_NONE)
					{
