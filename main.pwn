			format(string, sizeof(string), "News: /news, /live, /endlive, /liveban, /phonebook");
			ShowPlayerDialog(playerid, DIALOG_FHELP, DIALOG_STYLE_MSGBOX, "Factions Command List", string, "Like!","Back");
		}
		case FACTION_MECHANIC:
		{
			format(string, sizeof(string), "Mech: /tune, /repair, /tow, /untow, /refill, /nos, /hyd, /takecall\n\
			Mech: /upgradevehicle, /neon, /paintcar, /colorcar, /unmod");
			ShowPlayerDialog(playerid, DIALOG_FHELP, DIALOG_STYLE_MSGBOX, "Factions Command List", string, "Like!","Back");
		}
		case FACTION_GOVERNMENT:
		{
			format(string, sizeof(string), "Goverment: /gov, /settax, /factionpay, /tazer, /cuff, /uncuff, /detain, /taxdeposit, /taxwithdraw.\n\
			Goverment: /backup, /badge, /d, /flash");
			ShowPlayerDialog(playerid, DIALOG_FHELP, DIALOG_STYLE_MSGBOX, "Factions Command List", string, "Like!","Back");
		}
		case FACTION_HITMAN:
		{
			format(string, sizeof(string), "Hitman: /contracts, /takehit, /profile, /passport, /plantbomb, /pickupbomb, /detonate, /hmole, /hfind");
			ShowPlayerDialog(playerid, DIALOG_FHELP, DIALOG_STYLE_MSGBOX, "Factions Command List", string, "Like!","Back");
		}
		case FACTION_CARTEL:
		{
			format(string, sizeof(string), "Cartel: /locker, /craftweapon, /craftitem, /sellweapon");
			ShowPlayerDialog(playerid, DIALOG_FHELP, DIALOG_STYLE_MSGBOX, "Factions Command List", string, "Like!","Back");
		}
	}
	return 1;
}

