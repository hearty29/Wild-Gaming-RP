		}
	}
	return 1;
} 



CMD:bind(playerid, const params[])
{
	new level, option[8];

	if(!(0 <= level <= 8))
	{
		return SendClientMessage(playerid, COLOR_SYNTAX, "Invalid Slot. Bind Slot is 1 to 8 Only.");
	}
	if(sscanf(params, "s[8]", option))
	{
		SendClientMessage(playerid, COLOR_SYNTAX, "Usage: /bind [slot]");
		SendMessage(playerid, COLOR_GREY2, "[SLOT 1]: /me : %s",(PlayerInfo[playerid][pBind]));
		SendMessage(playerid, COLOR_GREY2, "[SLOT 2]: /me : %s",(PlayerInfo[playerid][pBind2]));
		SendMessage(playerid, COLOR_GREY2, "[SLOT 3]: /me : %s",(PlayerInfo[playerid][pBind3]));
		SendMessage(playerid, COLOR_GREY2, "[SLOT 4]: /me : %s",(PlayerInfo[playerid][pBind4]));
		SendMessage(playerid, COLOR_GREY2, "[SLOT 5]: /do : %s",(PlayerInfo[playerid][pBind5]));
		SendMessage(playerid, COLOR_GREY2, "[SLOT 6]: /do : %s",(PlayerInfo[playerid][pBind6]));
		SendMessage(playerid, COLOR_GREY2, "[SLOT 7]: /do : %s",(PlayerInfo[playerid][pBind7]));
		SendMessage(playerid, COLOR_GREY2, "[SLOT 8]: /do : %s",(PlayerInfo[playerid][pBind8]));
		return 1;
	}
	if(!strcmp(option, "1", true))
	{
		{
			SendProximityMessage(playerid, 20.0, SERVER_COLOR, "{C2A2DA}* %s %s", GetRPName(playerid), (PlayerInfo[playerid][pBind]));
			//CallLocalFunction("OnPlayerText", "s", (PlayerInfo[playerid][pBind]));
		}
	}
	if(!strcmp(option, "2", true))
	{
		{
			SendProximityMessage(playerid, 20.0, SERVER_COLOR, "{C2A2DA}* %s %s", GetRPName(playerid), (PlayerInfo[playerid][pBind2]));
		}
	}
	if(!strcmp(option, "3", true))
	{
		{
			SendProximityMessage(playerid, 20.0, SERVER_COLOR, "{C2A2DA}* %s %s", GetRPName(playerid), (PlayerInfo[playerid][pBind3]));
		}
	}
	if(!strcmp(option, "4", true))
	{
		{
			SendProximityMessage(playerid, 20.0, SERVER_COLOR, "{C2A2DA}* %s %s", GetRPName(playerid), (PlayerInfo[playerid][pBind4]));
		}
	}
	if(!strcmp(option, "5", true))
	{
		{
			SendProximityMessage(playerid, 20.0, SERVER_COLOR, "{C2A2DA} %s (( %s ))", (PlayerInfo[playerid][pBind5]), GetRPName(playerid));
		}
	}
	if(!strcmp(option, "6", true))
	{
		{
			SendProximityMessage(playerid, 20.0, SERVER_COLOR, "{C2A2DA} %s (( %s ))", (PlayerInfo[playerid][pBind6]), GetRPName(playerid));
		}
	}
	if(!strcmp(option, "7", true))
	{
		{
			SendProximityMessage(playerid, 20.0, SERVER_COLOR, "{C2A2DA} %s (( %s ))", (PlayerInfo[playerid][pBind7]), GetRPName(playerid));
		}
	}
	if(!strcmp(option, "8", true))
	{
		{
			SendProximityMessage(playerid, 20.0, SERVER_COLOR, "{C2A2DA} %s (( %s ))", (PlayerInfo[playerid][pBind8]), GetRPName(playerid));
		}
	}
	return 1;
}

CMD:buyclothes(playerid, const params[]) return callcmd::buy(playerid, params);
CMD:buy(playerid, const params[])
{
	new businessid = GetInsideBusiness(playerid), title[64], string[1024];

	if(businessid == -1)
	{
	    return SendClientMessage(playerid, COLOR_SYNTAX, "You are not inside of any business where you can buy stuff.");
	}
	if(BusinessInfo[businessid][bProducts] <= 0)
 	{
	 	return SendClientMessage(playerid, COLOR_SYNTAX, "This business is out of stock.");
   	}

	format(title, sizeof(title), "%s's %s (( %i Products ))", BusinessInfo[businessid][bOwner], bizInteriors[BusinessInfo[businessid][bType]][intType], BusinessInfo[businessid][bProducts]);

	switch(BusinessInfo[businessid][bType])
	{
	    case BUSINESS_STORE:
	    {
			if(!ShowingInventory[playerid]) {
