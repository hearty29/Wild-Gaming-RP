forward FlasherFunc();
public FlasherFunc() {
	new VEHICLE_PANEL_STATUS:panelsx,VEHICLE_DOOR_STATUS:doorsx,VEHICLE_LIGHT_STATUS:lightsx,VEHICLE_TYRE_STATUS:tiresx;
	for (new p=0; p<MAX_VEHICLES; p++)
	{
		if (Flasher[p] == 1)
		{
			if (FlasherState[p] == 1)
			{
				GetVehicleDamageStatus(p,panelsx,doorsx,lightsx,tiresx);
				UpdateVehicleDamageStatus(p, panelsx, doorsx, VEHICLE_LIGHT_STATUS:4, tiresx);
				FlasherState[p] = 0;
			}
			else
			{
				GetVehicleDamageStatus(p,panelsx,doorsx,lightsx,tiresx);
				UpdateVehicleDamageStatus(p, panelsx, doorsx, VEHICLE_LIGHT_STATUS:1, tiresx);
				FlasherState[p] = 1;
			}
		}
	}
	return 1;
}

