CMD:registercar(playerid, const params[])
{
	new vehicleid = GetPlayerVehicleID(playerid), Float:vpos[3];

	if(!IsPlayerInRangeOfPoint(playerid, 3.0, 2501.0352, -1946.1055, 13.4937))
	{
	    return SendClientMessage(playerid, COLOR_SYNTAX, "You are not in range of any DMV.");
	}
	if(!vehicleid || GetPlayerState(playerid) != PLAYER_STATE_DRIVER)
	{
	    return SendClientMessage(playerid, COLOR_SYNTAX, "You must be driving a vehicle to use this command.");
	}
	if(vehicleFuel[vehicleid] <= 0)
	{
	    return SendClientMessage(playerid, COLOR_SYNTAX, "There is no fuel left in this vehicle.");
	}

	if(VehicleInfo[vehicleid][vFactionType] != FACTION_NONE && GetFactionType(playerid) != VehicleInfo[vehicleid][vFactionType])
 	{
 		SendClientMessage(playerid, COLOR_SYNTAX, "This vehicle doesn't belong to your faction, therefore you can't register it.");
 		return 1;
	}
 	if(VehicleInfo[vehicleid][vGang] >= 0 && PlayerInfo[playerid][pGang] != VehicleInfo[vehicleid][vGang])
 	{
 		SendClientMessage(playerid, COLOR_SYNTAX, "This vehicle doesn't belong to your gang, therefore you can't register it.");
 		return 1;
 	}
	if(VehicleInfo[vehicleid][vOwnerID] > 0 && !IsVehicleOwner(playerid, vehicleid))
	{
 		return SendClientMessage(playerid, COLOR_SYNTAX, "This vehicle doesn't belong to you, therefore you can't register it.");
	}
	if(VehicleInfo[vehicleid][vRegistered])
	{
		return SendClientMessage(playerid, COLOR_SYNTAX, "This vehicle is already registered.");
	}
	if(PlayerInfo[playerid][pCash] < 50000)
	{
	    return SendClientMessage(playerid, COLOR_SYNTAX, "You must have $50,000 to register a vehicle.");
	}
	GetVehiclePos(vehicleid, vpos[0], vpos[1], vpos[2]);

	VehicleInfo[vehicleid][vRegistered] = 1;

	SendMessage(playerid, SERVER_COLOR, "You have successfully registered this vehicle.");
	PlayerInfo[playerid][pCash] -= 50000;
	ReloadVehicle(vehicleid);
	GetUniquePlate(vehicleid);
	SetVehiclePos(vehicleid, vpos[0], vpos[1], vpos[2] + 1);
	return 1;
}

stock GetUniquePlate(vehicleid) {
    new string[128], rows;

    for(new i = 0; i < 10; i++){

        format(string,sizeof(string),"%i-%c%c%c %i%i%i",random(10),(65+random(26)),(65+random(26)),(65+random(26)),random(10),random(10),random(10));
        printf("string begin of loop = %s",string);

        mysql_format(connectionID, queryBuffer, sizeof(queryBuffer), "SELECT plate FROM vehicles WHERE plate = '%e'", string);
        mysql_tquery(connectionID, queryBuffer);

        if(rows > 0)
        {
            printf("string already exists = %s",string);
            format(string,sizeof(string),"%i-%c%c%c %i%i%i",random(10),(65+random(26)),(65+random(26)),(65+random(26)),random(10),random(10),random(10));
        } else {
            format(VehicleInfo[vehicleid][vPlate],32, "%s", string);
            mysql_format(connectionID, queryBuffer, sizeof(queryBuffer), "UPDATE vehicles SET plate = '%e' WHERE id = %i", VehicleInfo[vehicleid][vPlate], VehicleInfo[vehicleid][vID]);
            mysql_tquery(connectionID, queryBuffer);
            SetVehicleNumberPlate(vehicleid, VehicleInfo[vehicleid][vPlate]);
            SetVehicleToRespawn(vehicleid);
            break;
        }
    }
    return 1;
}

forward OnPlayerDMVRelease(playerid);
public OnPlayerDMVRelease(playerid)
{
    new tickets = cache_get_field_content_int(0, "tickets");

    if(PlayerInfo[playerid][pCash] < tickets)
    {
        return SendMessage(playerid, COLOR_WHITE, "You need %s to release this impounded vehicle.", FormatNumber(tickets));
    }
    mysql_format(connectionID, queryBuffer, sizeof(queryBuffer), "UPDATE vehicles SET impounded = '0', tickets = '0' WHERE id = %i", cache_get_field_content_int(0, "id"));
    mysql_tquery(connectionID, queryBuffer);
    GivePlayerCash(playerid, -tickets);
    AddToTaxVault(tickets);
    SendMessage(playerid, -1, "You have paid %s to release your %s...", FormatNumber(tickets), vehicleNames[cache_get_field_content_int(0, "modelid") - 400]);
    return 1;
}

GetVehicleModelName(modelid) {
    new string[32];

    if (400 <= modelid <= 611)
        strcpy(string, vehicleNames[modelid - 400]);

    else
        string = "Unknown";

    return string;
}

stock IsLoadableVehicle(vehicleid) {
    new modelid = GetVehicleModel(vehicleid);

    if (GetVehicleTrailer(vehicleid))
        modelid = GetVehicleModel(GetVehicleTrailer(vehicleid));

    switch (modelid) {
        case 400..609: return 1;
    }
    return 0;
}

ShowTicketList(playerid) {
    mysql_format(connectionID, queryBuffer, sizeof(queryBuffer), "SELECT * FROM vehicles WHERE tickets > 0 AND ownerid = %d ORDER BY ID DESC", PlayerInfo[playerid][pID]);
    mysql_tquery(connectionID, queryBuffer, "OnPlayerShowTickets", "i", playerid);
}

PlayerCanAfford(playerid, amount) {
    return PlayerInfo[playerid][pCash] >= amount;
}

forward OnPlayerShowTickets(playerid);
public OnPlayerShowTickets(playerid)
{
    new rows = cache_get_row_count(connectionID);
    if(!rows)
    {
        SendClientMessage(playerid, -1, "You don't have any tickets to pay.");
    }
    else
    {
        static modelid, amount;
        for (new i = 0; i < rows; i ++)
        {
            amount = cache_get_field_content_int(i, "tickets");
            modelid = cache_get_field_content_int(i, "modelid");
            format(gListString, sizeof(gListString), "%s\t%s\n", GetVehicleModelName(modelid), FormatNumber(amount));
            gListedItems[playerid][i] = cache_get_field_content_int(i, "ownerid");
        }
        ShowPlayerDialog(playerid, DIALOG_PAYTICKET, DIALOG_STYLE_LIST, "{FFFFFF}Tickets to Pay", gListString, "Pay", "Cancel");
    }
}

forward OnPlayerPayTicket(playerid, ticket);
public OnPlayerPayTicket(playerid, ticket)
{
    new rows = cache_get_row_count(connectionID);
    if(!rows)
    {
        SendMessage(playerid, -1, "There was an error processing this ticket.");
    }
    else
    {
        new amount, modelid;

        amount = cache_get_field_content_int(0, "tickets");
        modelid = cache_get_field_content_int(0, "modelid");

        if(!PlayerCanAfford(playerid, amount))
        {
            SendMessage(playerid, -1, "You don't have enough money to pay this ticket.");
        }
        else
        {
            mysql_format(connectionID, queryBuffer, sizeof(queryBuffer), "UPDATE vehicles SET tickets = 0 WHERE ownerid = %d", ticket);
            mysql_tquery(connectionID, queryBuffer);

            SendMessage(playerid, -1, "You have paid a ticket costing %s issued in your %s.", FormatNumber(amount), GetVehicleModelName(modelid));
            GivePlayerCash(playerid, -amount);
            ShowTicketList(playerid);
        }
    }
}

IsPlayerAtDmvStation(playerid)
{
    if(IsPlayerInRangeOfPoint(playerid, 3.0, 830.66, -0.26, 1004.17) || IsPlayerInRangeOfPoint(playerid, 3.0, 833.60, 3.23, 1004.17)) {
        return 1;
	}
	return 0;
}

CMD:dmvmenu(playerid, const params[])
{
	if(!IsPlayerAtDmvStation(playerid))
	{
	    return SendClientMessage(playerid, COLOR_SYNTAX, "You're not at the DMV release point in Dillimore (inside the DMV).");
	}
	if(PlayerInfo[playerid][pCarLicense] == 0)
	{
		SendClientMessage(playerid, COLOR_SYNTAX, "A valid driver's license is required to release your vehicle from the impound, or pay any tickets.");
		return 1;
	}
	ShowPlayerDialog(playerid, DIALOG_VEHICLEMENU, DIALOG_STYLE_LIST, "{FFFFFF}Tickets/Impounding", "Pay Tickets\nRelease Vehicle", "Select", "Cancel");

	return 1;
}
		
CMD:impound(playerid)
{
    new trailer = GetPlayerVehicleID(playerid), 
		vehicleid = GetVehicleTrailer(trailer);
		
	if(GetNearbyImpound(playerid) >= 0)
	{
		if((FactionInfo[PlayerInfo[playerid][pFaction]][fType] != FACTION_MECHANIC) && !IsLawEnforcement(playerid))
			return SendClientMessage(playerid, COLOR_SYNTAX, "You must be a Mechanic or a Law Enforcement Officer to use this command.");

		if (GetVehicleModel(trailer) != 525)
			return SendClientMessage(playerid, COLOR_SYNTAX, "You are not driving a tow truck.");

		if(!IsPlayerInRangeOfPoint(playerid, 6.0, 844.949218, -601.396423, 14.421875))
			return SendClientMessage(playerid, COLOR_SYNTAX, "You're not in range of impound lots, go to dillimore");

		if (!GetVehicleTrailer(trailer))
			return SendClientMessage(playerid, COLOR_SYNTAX, "There is no vehicle hooked.");

		if (vehicleid == -1)
			return SendClientMessage(playerid, COLOR_GREY, "You can't tow this vehicle.");

		if(!IsValidVehicle(vehicleid) || !VehicleInfo[vehicleid][vID])
		{
			return SendClientMessage(playerid, COLOR_GREY, "The vehicle specified is invalid or a static vehicle.");
		}
		if(!VehicleInfo[vehicleid][vOwnerID])
		{
			return SendClientMessage(playerid, COLOR_GREY, "You can only impound player's owned vehicles.");
		}
		VehicleInfo[vehicleid][vPosX] = 830.1310;
		VehicleInfo[vehicleid][vPosY] = -611.6267;
		VehicleInfo[vehicleid][vPosZ] = 16.0483;
		VehicleInfo[vehicleid][vPosA] = 0.5198;
		VehicleInfo[vehicleid][vInterior] = 0;
		VehicleInfo[vehicleid][vWorld] = 0;

		mysql_format(connectionID, queryBuffer, sizeof(queryBuffer), "UPDATE vehicles SET impounded = '1', pos_x = '%f', pos_y = '%f', pos_z = '%f', pos_a = '%f', interior = %i, world = %i WHERE id = %i", VehicleInfo[vehicleid][vPosX], VehicleInfo[vehicleid][vPosY], VehicleInfo[vehicleid][vPosZ], VehicleInfo[vehicleid][vPosA], VehicleInfo[vehicleid][vInterior], VehicleInfo[vehicleid][vWorld], VehicleInfo[vehicleid][vID]);
		mysql_tquery(connectionID, queryBuffer);
		mysql_format(connectionID, queryBuffer, sizeof(queryBuffer), "UPDATE vehicles SET impounded = '1', pos_x = '%f', pos_y = '%f', pos_z = '%f', pos_a = '%f', interior = %i, world = %i WHERE id = %i", VehicleInfo[vehicleid][vPosX], VehicleInfo[vehicleid][vPosY], VehicleInfo[vehicleid][vPosZ], VehicleInfo[vehicleid][vPosA], VehicleInfo[vehicleid][vInterior], VehicleInfo[vehicleid][vWorld], VehicleInfo[vehicleid][vID]);
		mysql_tquery(connectionID, queryBuffer);

		new szMessage[96];
		format(szMessage, sizeof(szMessage),"* You have Successfully impounded %s.", GetVehicleName(vehicleid));
		SendClientMessage(playerid, COLOR_LIGHTBLUE, szMessage);

		format(szMessage, sizeof(szMessage), "HQ: %s %s has impounded %s's %s ($%i unpaid tickets).", FactionRanks[PlayerInfo[playerid][pFaction]][PlayerInfo[playerid][pFactionRank]], GetRPName(playerid), GetVehicleName(vehicleid), FormatNumber(VehicleInfo[vehicleid][vTickets]));
		SendFactionMessage(PlayerInfo[playerid][pFaction], COLOR_ROYALBLUE, szMessage);

		DetachTrailerFromVehicle(GetPlayerVehicleID(playerid));
		DespawnVehicle(vehicleid);
	} else {
		SendClientMessage(playerid, COLOR_SYNTAX, "You are not in range of impound yard.");
	}
    return 1;
}

CMD:giveweapon(playerid, const params[])
{
	new string[128], targetid, weaponid = GetScriptWeapon(playerid), ammoid = GetPlayerAmmo(playerid);
	if(PlayerInfo[playerid][pInjured] > 0 || PlayerInfo[playerid][pTazedTime] > 0 || PlayerInfo[playerid][pCuffed] > 0 || PlayerInfo[playerid][pDueling] != INVALID_PLAYER_ID)
	{
	    return SendClientMessage(playerid, COLOR_GREY, "You can't use this command at the moment.");
	}
	if(PlayerInfo[playerid][pFaction] >= 0)
	{
	    return SendClientMessage(playerid, COLOR_GREY, "You cannot use this command while in a faction.");
	}
	if(sscanf(params, "us[64]", targetid))
	{
		SendClientMessageEx(playerid, COLOR_GREY, "USAGE: /giveweapon [playerid]");
		return 1;
	}
	if(GetHealth(playerid) < 80)
	{
	    return SendClientMessage(playerid, COLOR_SYNTAX, "You can't give weapons if your health is below 80.");
	}
	if(!weaponid)
	{
	    return SendClientMessage(playerid, COLOR_SYNTAX, "You must be holding the weapon you're willing to give.");
	}
	if (!IsPlayerConnected(targetid)) 
	{
		return SendClientMessage(playerid, COLOR_SYNTAX, "Invalid player specified.");
	}
	if(targetid == playerid)
	{
	    return SendClientMessage(playerid, COLOR_SYNTAX, "You can't use this command on yourself.");
	}
	if(IsPlayerInAnyVehicle(playerid))
	{
		SendClientMessage(playerid, COLOR_SYNTAX, "You can not give weapons in a vehicle!");
		return 1;
	}
	if(!IsPlayerInRangeOfPlayer(playerid, targetid, 3.0))
	{
	    return SendClientMessage(playerid, COLOR_SYNTAX, "The player specified is disconnected or out of range.");
	}
	if(PlayerInfo[targetid][pLevel] == 1)
	{
		return SendClientMessage(playerid, COLOR_SYNTAX, "You can not give weapons in level 1 player");
	}

	format(string, sizeof(string), "* %s has given %s their %s.", GetPlayerNameEx(playerid), GetPlayerNameEx(targetid), GetWeaponNameEx(weaponid));
	ProxDetector(30.0, playerid, string, COLOR_PURPLE,COLOR_PURPLE,COLOR_PURPLE,COLOR_PURPLE,COLOR_PURPLE);
	
	GivePlayerWeaponEx(targetid, weaponid, ammoid);
	RemovePlayerWeaponEx(playerid, weaponid);
	return 1;
}

// Cartel Faction
CMD:sellweapon(playerid, const params[])
{
	new string[128], targetid, weaponid = GetScriptWeapon(playerid), ammoid = GetPlayerAmmo(playerid), price;
	if(GetFactionType(playerid) != FACTION_CARTEL)
    {
        return SendClientMessage(playerid, COLOR_SYNTAX, "You can't use this command as you aren't apart of cartel.");
	}
	if(PlayerInfo[playerid][pInjured] > 0 || PlayerInfo[playerid][pTazedTime] > 0 || PlayerInfo[playerid][pCuffed] > 0 || PlayerInfo[playerid][pDueling] != INVALID_PLAYER_ID)
	{
	    return SendClientMessage(playerid, COLOR_GREY, "You can't use this command at the moment.");
	}
	if(PlayerInfo[playerid][pFaction] >= 0)
	{
	    return SendClientMessage(playerid, COLOR_GREY, "You cannot use this command while in a faction.");
	}
	if(sscanf(params, "us[64]d", targetid, price))
	{
		SendClientMessageEx(playerid, COLOR_GREY, "USAGE: /sellweapon [playerid] [price]");
		return 1;
	}
	if(!(1 <= price <= 1000000))
    {
        return SendMessage(playerid, COLOR_SYNTAX, "Don't go below $1, or above $1,000,000 at once.");
    }
	if(GetHealth(playerid) < 80)
	{
	    return SendClientMessage(playerid, COLOR_SYNTAX, "You can't give weapons if your health is below 80.");
	}
	if(!weaponid)
	{
	    return SendClientMessage(playerid, COLOR_SYNTAX, "You must be holding the weapon you're willing to give.");
	}
	if (!IsPlayerConnected(targetid)) 
	{
		return SendClientMessage(playerid, COLOR_SYNTAX, "Invalid player specified.");
	}
	if(targetid == playerid)
	{
	    return SendClientMessage(playerid, COLOR_SYNTAX, "You can't use this command on yourself.");
	}
	if(!IsPlayerInRangeOfPlayer(playerid, targetid, 3.0))
	{
	    return SendClientMessage(playerid, COLOR_SYNTAX, "The player specified is disconnected or out of range.");
	}
	
	format(string, sizeof(string), "* %s has sell %s their %s amount of %d.", GetPlayerNameEx(playerid), GetPlayerNameEx(targetid), GetWeaponNameEx(weaponid), price);
	ProxDetector(30.0, playerid, string, COLOR_PURPLE,COLOR_PURPLE,COLOR_PURPLE,COLOR_PURPLE,COLOR_PURPLE);
	
	GivePlayerCash(playerid, -price);
	GivePlayerCash(playerid, price);
	
	GivePlayerWeaponEx(targetid, weaponid, ammoid);
	RemovePlayerWeaponEx(playerid, weaponid);
	return 1;
}

