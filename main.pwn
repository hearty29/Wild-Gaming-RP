forward PlayerSpawn(playerid);
public PlayerSpawn(playerid)
{
	if(PlayerInfo[playerid][pLogged] && PlayerInfo[playerid][pTutorial])
	{	
		ClearChat(playerid);
		InsideTut[playerid] = 0;
		PlayerInfo[playerid][pTutorial] = 0;
		PlayerInfo[playerid][pSetup] = 0;

		SetPlayerSkin(playerid, PlayerInfo[playerid][pSkin]);
		SetPlayerPos(playerid, 1451.4000,-2286.9634,13.5469);
		SetPlayerFacingAngle(playerid, 92.2265);
		SetPlayerVirtualWorld(playerid, 0);
		SetPlayerInterior(playerid, 0);
		SetCameraBehindPlayer(playerid);
		StopAudioStreamForPlayer(playerid);
		TogglePlayerControllable(playerid, 1);

		mysql_format(connectionID, queryBuffer, sizeof(queryBuffer), "UPDATE users SET setup = 0, gender = %i, age = %i, skin = %i WHERE uid = %i", PlayerInfo[playerid][pGender], PlayerInfo[playerid][pAge], PlayerInfo[playerid][pSkin], PlayerInfo[playerid][pID]);
		mysql_tquery(connectionID, queryBuffer);
	}
}

stock Alert(playerid, const string[], time = 5000)
{
	if(PlayerInfo[playerid][pAlert])
	{
		for(new td = 0; td < 3; td ++)
		{
			PlayerTextDrawHide(playerid, AlertTD[playerid][td]);
			PlayerTextDrawDestroy(playerid, AlertTD[playerid][td]);
		}
		KillTimer(PlayerInfo[playerid][pAlertTimer]);
	}

	AlertTD[playerid][0] = CreatePlayerTextDraw(playerid, 500.000000, 117.000000, string);
	PlayerTextDrawFont(playerid, AlertTD[playerid][0], TEXT_DRAW_FONT:1);
	PlayerTextDrawLetterSize(playerid, AlertTD[playerid][0], 0.204165, 1.200000);
	PlayerTextDrawTextSize(playerid, AlertTD[playerid][0], 608.500000, 517.000000);
	PlayerTextDrawSetOutline(playerid, AlertTD[playerid][0], 0);
	PlayerTextDrawSetShadow(playerid, AlertTD[playerid][0], 0);
	PlayerTextDrawAlignment(playerid, AlertTD[playerid][0], TEXT_DRAW_ALIGN:1);
	PlayerTextDrawColour(playerid, AlertTD[playerid][0], -741092353);
	PlayerTextDrawBackgroundColour(playerid, AlertTD[playerid][0], 255);
	PlayerTextDrawBoxColour(playerid, AlertTD[playerid][0], 135);
	PlayerTextDrawUseBox(playerid, AlertTD[playerid][0], 1);
	PlayerTextDrawSetProportional(playerid, AlertTD[playerid][0], 1);
	PlayerTextDrawSetSelectable(playerid, AlertTD[playerid][0], 0);

	for(new td = 0; td < 3; td ++)
	{
		PlayerTextDrawShow(playerid, AlertTD[playerid][td]);
	}

	PlayerInfo[playerid][pAlert] = true;
	PlayerInfo[playerid][pAlertTimer] = SetTimerEx("HideAlert", time, false, "d", playerid);
	return 1;
}

forward HideAlert(playerid);
public HideAlert(playerid)
{
	if (!PlayerInfo[playerid][pAlert])
	    return 0;

	PlayerInfo[playerid][pAlert] = false;

	for(new td = 0; td < 3; td ++)
	{
		PlayerTextDrawHide(playerid, AlertTD[playerid][td]);
		PlayerTextDrawDestroy(playerid, AlertTD[playerid][td]);
	}
	return 1;
}

forward Countdown(playerid, count);
public Countdown(playerid, count)
{
	foreach(new i : Player)
	{
	    if(PlayerInfo[i][pJoinedEvent])
	    {
	        switch(count)
	        {
	        	case 3:
				{
					GameTextForPlayer(i, "3", 1000, 5);
					PlayerPlaySound(i, 1056, 0.0, 0.0, 0.0);
				}
				case 2:
				{
					GameTextForPlayer(i, "2", 1000, 5);
					PlayerPlaySound(i, 1056, 0.0, 0.0, 0.0);
				}
				case 1:
				{
					GameTextForPlayer(i, "1", 1000, 5);
					PlayerPlaySound(i, 1056, 0.0, 0.0, 0.0);
				}
				case 0:
				{
					GameTextForPlayer(i, "Go! Go! Go!", 1000, 5);
					PlayerPlaySound(i, 1057, 0.0, 0.0, 0.0);
				}
			}
		}
	}
	count--;
	if(count >= 0)
	{
 		SetTimerEx("Countdown", 1000, false, "ii", playerid, count);
	}
}

