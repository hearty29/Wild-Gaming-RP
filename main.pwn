			    Log_Write("log_give", "%s (uid: %i) has sold their %i backpack to %s (uid: %i) for $%i.", GetPlayerNameEx(offeredby), PlayerInfo[offeredby][pID], size, GetPlayerNameEx(playerid), PlayerInfo[playerid][pID], price);

